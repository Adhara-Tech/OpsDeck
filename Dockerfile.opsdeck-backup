# ============================================
# OpsDeck Backup Image
# Used by the backup CronJob defined in helm/templates/cronjob-backup.yaml.
# Bundles pg_dump (postgresql-client) and restic so the CronJob script can
# dump the DB and push it together with the attachments PVC to an S3 repo.
# ============================================
FROM alpine:3.20

RUN apk add --no-cache \
        ca-certificates \
        tzdata \
        postgresql16-client \
        restic \
    && update-ca-certificates

ENTRYPOINT ["sh"]
