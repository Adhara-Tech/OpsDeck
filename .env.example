# Flask Configuration
# --------------------
# A long, random string used for signing sessions and other security purposes.
# Generate a good one with: python -c 'import secrets; print(secrets.token_hex(24))'
SECRET_KEY='your-very-strong-and-random-secret-key-goes-here'

# Tells Flask how to find and load the application.
FLASK_APP=run:app


# Database Configuration
# ----------------------
# The connection URI for your database.
# Defaults to a local SQLite file if not set.
# Example for PostgreSQL: DATABASE_URL='postgresql://user:password@host:port/dbname'
# DATABASE_URL=


# SMTP Email Notification Settings (Optional)
# ---------------------------------------------
# Fill these out to enable email notifications.
# For Gmail, you will need to generate an "App Password".
SMTP_SERVER='smtp.gmail.com'
SMTP_PORT=587
EMAIL_USERNAME='your-email@gmail.com'
EMAIL_PASSWORD='your-gmail-app-password'


# Webhook Notification Settings (Optional)
# ----------------------------------------
# The URL to send a POST request to for webhook notifications.
# Can be a Slack Incoming Webhook, Discord Webhook, etc.
WEBHOOK_URL=


# Google OAuth Settings (Optional)
# ---------------------------------
# Credentials from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
# Set to 1 for local development (HTTP), 0 in production (HTTPS)
OAUTHLIB_INSECURE_TRANSPORT=1
