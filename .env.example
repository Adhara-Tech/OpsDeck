# Flask Configuration
# --------------------
# A long, random string used for signing sessions and other security purposes.
# Generate a good one with: python -c 'import secrets; print(secrets.token_hex(24))'
SECRET_KEY='your-very-strong-and-random-secret-key-goes-here'


# Tells Flask how to find and load the application.
FLASK_APP=run:app

# Enables debug mode (1 for dev, 0 for prod)
FLASK_DEBUG=0

# Demo data (True for dev, False for prod)
SEED_DEMO_DATA=True


# Database Configuration
# ----------------------
# The connection URI for your database.
# Defaults to a local SQLite file if not set.
# Example for PostgreSQL: DATABASE_URL='postgresql://user:password@host:port/dbname'
# DATABASE_URL=


# SMTP Email Notification Settings (Optional)
# ---------------------------------------------
# Fill these out to enable email notifications.
# For Gmail, you will need to generate an "App Password".
SMTP_SERVER='smtp.gmail.com'
SMTP_PORT=587
EMAIL_USERNAME='your-email@gmail.com'
EMAIL_PASSWORD='your-gmail-app-password'


# Webhook Notification Settings (Optional)
# ----------------------------------------
# The URL to send a POST request to for webhook notifications.
# Can be a Slack Incoming Webhook, Discord Webhook, etc.
WEBHOOK_URL=


# Slack Bot Integration (Optional)
# ---------------------------------
# Bot User OAuth Token for sending Slack notifications.
# Must start with 'xoxb-'. Get it from your Slack App settings:
# https://api.slack.com/apps > Your App > OAuth & Permissions
# Required scopes: chat:write, users:read, users:read.email
SLACK_BOT_TOKEN=


# Google OAuth Settings (Optional)
# ---------------------------------
# Credentials from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
# Set to 1 for local development (HTTP), 0 in production (HTTPS)
OAUTHLIB_INSECURE_TRANSPORT=1


# MFA Configuration (Optional)
# -----------------------------
# Enable/disable IP-based MFA. When enabled, users logging from unknown IPs
# will receive an OTP code via email.
MFA_ENABLED=True

# Session configuration
SESSION_COOKIE_SECURE=True # Only in Prod with HTTPS
SESSION_COOKIE_HTTPONLY=True # Default in Flask, but better to set explicitly
SESSION_COOKIE_SAMESITE='Lax' # Or 'Strict'


# Admin User Initialization (Optional)
# -------------------------------------
# Credentials for the initial admin user created on first deployment.
# These are only used if no users exist in the database.
# Change these values in production for security.
DEFAULT_ADMIN_EMAIL='admin@example.com'
DEFAULT_ADMIN_INITIAL_PASSWORD='admin123'
